# video-processor — пример конфига
# Скопировать в .env.processor и заполнить.

# ============================================================================
# Сервисные переменные
# ============================================================================
PROCESSOR_TOKEN=change-me-worker-token
PROCESSOR_ADMIN_TOKEN=change-me-admin-token

# Fernet master key. Сгенерировать:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROCESSOR_KEY_ENCRYPTION_KEY=

MEDIA_DIR=/media
DB_DIR=/db

MAX_CONCURRENT_TRANSCRIBE=2
MAX_CONCURRENT_VISION=4

# ============================================================================
# Bootstrap AI-ключей (опционально, вставляются в keys.db при первом старте)
# Если не заполнены — добавляйте вручную через POST /admin/api-keys
# ============================================================================

# --- Транскрипция ---
BOOTSTRAP_ASSEMBLYAI_API_KEY=
BOOTSTRAP_DEEPGRAM_API_KEY=
BOOTSTRAP_OPENAI_WHISPER_API_KEY=
BOOTSTRAP_GROQ_API_KEY=

# --- Vision / LLM ---
BOOTSTRAP_ANTHROPIC_API_KEY=
BOOTSTRAP_OPENAI_API_KEY=
BOOTSTRAP_GOOGLE_GEMINI_API_KEY=
