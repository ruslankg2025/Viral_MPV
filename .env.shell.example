# shell/orchestrator — пример конфига (закоммичен)
# Реальный файл — .env.shell, gitignored.

# ============================================================================
# Orchestrator (pipeline download → analyze → ...)
# ============================================================================
DB_DIR=/db

# URL соседних сервисов внутри docker-сети
DOWNLOADER_URL=http://downloader:8000
DOWNLOADER_TOKEN=dev-downloader-token-change-me

PROCESSOR_URL=http://processor:8000
PROCESSOR_TOKEN=dev-worker-token-change-me

# Таймауты
ORCHESTRATOR_RUN_TIMEOUT_SEC=600
ORCHESTRATOR_POLL_INTERVAL_SEC=1.0

# Recovery: run, не обновлявшийся дольше этого, при старте → status='failed'
ORCHESTRATOR_STALLED_TIMEOUT_SEC=300

# ============================================================================
# Insights — read-only-доступ к ccpm.poll_responses (метрики от Алины).
# Если оставить пустым — endpoint /api/insights/* отдаст 503, фронт
# покажет «нет данных» в плитках без падения.
# Формат DSN asyncpg: postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Для прод-сервера VIRA на vira.roxber.com (postgres native, listens
# only on 127.0.0.1): нужно настроить host.docker.internal через
# extra_hosts в compose + listen_addresses в postgresql.conf.
# Пример (production):
#   CCPM_DATABASE_URL=postgresql://upravlenec:CHANGE_ME@host.docker.internal:5432/upravlenec
# ============================================================================
CCPM_DATABASE_URL=
