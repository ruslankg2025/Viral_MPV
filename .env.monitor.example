MONITOR_TOKEN=dev-token-change-me
MONITOR_ADMIN_TOKEN=dev-admin-token-change-me
DB_DIR=/db

# YouTube Data API v3 (get at https://console.cloud.google.com/apis/credentials).
# Leave empty to auto-enable per-platform fake mode for youtube.
YOUTUBE_API_KEY=

# Apify (Instagram + TikTok через run-sync-get-dataset-items API).
# Токен: https://console.apify.com/account/integrations
# Пусто → fake mode для instagram/tiktok (из fixtures/).
APIFY_TOKEN=
# Actor IDs используют "~" вместо "/" в URL
APIFY_INSTAGRAM_ACTOR=apify~instagram-scraper
APIFY_TIKTOK_ACTOR=clockworks~tiktok-scraper
APIFY_TIMEOUT_SEC=180
APIFY_RESULTS_LIMIT=30

# Profile service integration
PROFILE_BASE_URL=http://profile:8000
PROFILE_TOKEN=dev-token-change-me

# Fake mode: forced — не ходит в сеть ни одна платформа, возвращает fixtures/.
# Если false, per-platform fake включается автоматически при пустом ключе
# (YOUTUBE_API_KEY / APIFY_TOKEN).
MONITOR_FAKE_FETCH=false

# Scheduler
CRAWL_DEFAULT_INTERVAL_MIN=60
CRAWL_MAX_CONCURRENT=3

# Trending thresholds
TRENDING_ZSCORE_THRESHOLD=2.0
TRENDING_GROWTH_THRESHOLD=0.5
TRENDING_MIN_VIEWS=100
