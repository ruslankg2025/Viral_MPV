# video-downloader — пример конфига (закоммичен)
# Реальный файл — .env.downloader, gitignored.

# ============================================================================
# Сервисные переменные
# ============================================================================
DOWNLOADER_TOKEN=dev-downloader-token-change-me

MEDIA_DIR=/media
DB_DIR=/db

# Этап 1: stub-режим возвращает /app/fixtures/test_fixture.mp4 вместо реальной скачки.
# Этап 4: STUB_MODE=false включает живые стратегии (yt-dlp → Apify fallback).
STUB_MODE=true

# ============================================================================
# Лимиты
# ============================================================================
MAX_CONCURRENT=3
JOB_TIMEOUT_SEC=300
TTL_FAILED_HOURS=24

# ============================================================================
# Этап 4 (живые стратегии)
# ============================================================================
# APIFY_TOKEN — для Apify-акторов (IG primary, TT fallback).
# Можно использовать тот же токен, что у monitor.
APIFY_TOKEN=

# Apify actor IDs (URL-формат с ~).
# Дефолты:
#   IG: apify~instagram-scraper (поддерживает directUrls и videoUrl в ответе)
#   TT: clockworks~tiktok-scraper (поддерживает postURLs + shouldDownloadVideos=true)
APIFY_INSTAGRAM_ACTOR=apify~instagram-scraper
APIFY_TIKTOK_ACTOR=clockworks~tiktok-scraper

# Опц. путь к Netscape-cookies для Instagram. Без него приватный контент недоступен.
# Положить файл в /media/secrets/instagram.cookies, путь — `/media/secrets/instagram.cookies`.
INSTAGRAM_COOKIES_FILE=
