# viral-script — пример конфига
# Скопировать в .env.script и заполнить.

# ============================================================================
# Сервисные переменные
# ============================================================================
SCRIPT_TOKEN=change-me-worker-token
SCRIPT_ADMIN_TOKEN=change-me-admin-token

# Fernet master key. Сгенерировать:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SCRIPT_KEY_ENCRYPTION_KEY=

DB_DIR=/db

# Дефолтный провайдер text generation (выбирается resolver'ом при отсутствии
# явного provider в payload /script/generate).
DEFAULT_TEXT_PROVIDER=anthropic_claude_text

# Если 1 — ... (зарезервировано). В MVP всегда 0.
SCRIPT_FAKE_LLM=0

# ============================================================================
# Bootstrap AI-ключей (опционально, вставляются в keys.db при первом старте)
# Если не заполнены — добавляйте вручную через POST /script/admin/api-keys
# ============================================================================

BOOTSTRAP_ANTHROPIC_API_KEY=
BOOTSTRAP_OPENAI_API_KEY=
